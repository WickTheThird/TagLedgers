# Google OAuth (for user login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/callback

# Google Service Account (for accessing owner's Drive folders)
# Create at: console.cloud.google.com > IAM > Service Accounts > Create > Keys > JSON
# Share your Drive folders with the service account email
# Paste the ENTIRE JSON key as a single line
GOOGLE_SERVICE_ACCOUNT_KEY=

# Google Drive folder IDs (comma-separated)
# Find in URL: drive.google.com/drive/folders/THIS_IS_THE_ID
DRIVE_FOLDER_IDS=

# Allowed user emails (comma-separated, leave empty to allow all)
ALLOWED_EMAILS=
